#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PKG_NAME="io.ionic.starter"

if [[ "$#" -ne 2 ]]; then
  echo "Usage: android-install [debug|release] <device-id>" >&2
  exit 2
fi

MODE="$1"
DEVICE_ID="$2"

if ! command -v adb >/dev/null 2>&1; then
  echo "adb not found in PATH" >&2
  exit 1
fi

if ! adb devices >/dev/null 2>&1; then
  echo "adb failed; is the Android platform-tools/adb available?" >&2
  exit 1
fi

if ! adb devices | awk 'NR>1 && $1 == serial && $2 == "device" {found = 1} END {exit found ? 0 : 1}' serial="${DEVICE_ID}"; then
  echo "ADB device '${DEVICE_ID}' not found or not ready." >&2
  echo "Available devices:" >&2
  adb devices >&2
  exit 1
fi

case "${MODE}" in
  debug)
    OUTPUT_DIR="${ROOT_DIR}/android/app/build/outputs/apk/debug"
    ;;
  release)
    OUTPUT_DIR="${ROOT_DIR}/android/app/build/outputs/apk/release"
    ;;
  *)
    echo "Usage: android-install [debug|release] <device-id>" >&2
    exit 2
    ;;
esac

METADATA_PATH="${OUTPUT_DIR}/output-metadata.json"

if [[ ! -f "${METADATA_PATH}" ]]; then
  echo "APK metadata not found: ${METADATA_PATH}" >&2
  if [[ "${MODE}" == "debug" ]]; then
    echo "Build it first: npm run build:debug" >&2
  else
    echo "Build it first: npm run build" >&2
  fi
  exit 1
fi

APK_FILE_NAME="$({ node --input-type=module -e '
import fs from "node:fs";

const metadataPath = process.argv[1];
const metadata = JSON.parse(fs.readFileSync(metadataPath, "utf8"));
const outputFile = metadata?.elements?.[0]?.outputFile;

if (typeof outputFile !== "string" || outputFile.length === 0) {
  process.exit(1);
}

process.stdout.write(outputFile);
' "${METADATA_PATH}"; } )" || {
  echo "Could not determine APK name from: ${METADATA_PATH}" >&2
  exit 1
}

APK_PATH="${OUTPUT_DIR}/${APK_FILE_NAME}"

if [[ ! -f "${APK_PATH}" ]]; then
  echo "APK not found: ${APK_PATH}" >&2
  if [[ "${MODE}" == "debug" ]]; then
    echo "Build it first: npm run build:debug" >&2
  else
    echo "Build it first: npm run build" >&2
  fi
  exit 1
fi

if [[ "${MODE}" == "release" && "${APK_FILE_NAME}" == *-unsigned.apk ]]; then
  echo "Release APK is unsigned and cannot be installed: ${APK_PATH}" >&2
  echo "Configure Android release signing or keep the local debug signing config in android/app/build.gradle." >&2
  exit 1
fi

adb -s "${DEVICE_ID}" install -r "${APK_PATH}"
adb -s "${DEVICE_ID}" shell monkey -p "${PKG_NAME}" -c android.intent.category.LAUNCHER 1 >/dev/null 2>&1 || true
